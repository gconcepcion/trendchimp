# --- Alpaca credentials (paper keys from https://app.alpaca.markets/paper/dashboard/overview) ---
TRENDCHIMP_ALPACA__API_KEY=your_paper_key_here
TRENDCHIMP_ALPACA__SECRET_KEY=your_paper_secret_here
TRENDCHIMP_ALPACA__PAPER=true
TRENDCHIMP_ALPACA__DATA_FEED=iex

# --- Live-trading double lock (KEEP BOTH AT DEFAULT FOR PAPER) ---
# To go live you must set PAPER=false AND the line below to true. Do not do this in v1.
TRENDCHIMP_LIVE_TRADING_CONFIRMED=false

# --- Trading universe ---
TRENDCHIMP_TRADING__SYMBOLS=["AAPL","MSFT","SPY","TSLA"]
TRENDCHIMP_TRADING__TIMEFRAME=1Day
TRENDCHIMP_TRADING__DRY_RUN=false
# If set and present, the bot trades the symbols in this file (written by
# `trendchimp screen`) instead of SYMBOLS above. Leave blank to use SYMBOLS.
TRENDCHIMP_TRADING__UNIVERSE_FILE=

# --- AI screener (`trendchimp screen`) ---
TRENDCHIMP_SCREENER__ANTHROPIC_API_KEY=sk-ant-your-key-here
TRENDCHIMP_SCREENER__MODEL=claude-opus-4-8
TRENDCHIMP_SCREENER__TOP_N_TECHNICAL=30
TRENDCHIMP_SCREENER__FINAL_PICKS=10
TRENDCHIMP_SCREENER__LOOKBACK_DAYS=260
TRENDCHIMP_SCREENER__CACHE_DIR=./cache
# Price band for screener candidates (0 = no limit, the default). Set MAX_PRICE to
# build a universe a small account can actually size into (see small-account preset).
TRENDCHIMP_SCREENER__MIN_PRICE=0
TRENDCHIMP_SCREENER__MAX_PRICE=0

# --- Strategy: Donchian / Turtle (System 1 defaults) ---
TRENDCHIMP_STRATEGY__NAME=donchian_breakout
# JSON object; entry/exit/atr periods and 2N stop multiplier
TRENDCHIMP_STRATEGY__PARAMS={"entry_channel":20,"exit_channel":10,"atr_period":20,"atr_stop_mult":2.0,"allow_short":true,"breakout_on":"high_low"}

# --- Risk guardrails ---
TRENDCHIMP_RISK__RISK_PER_TRADE_PCT=0.01
TRENDCHIMP_RISK__ATR_STOP_MULT=2.0
TRENDCHIMP_RISK__MAX_OPEN_POSITIONS=10
TRENDCHIMP_RISK__MAX_UNITS_PER_SYMBOL=1
TRENDCHIMP_RISK__DAILY_LOSS_LIMIT_PCT=0.02
TRENDCHIMP_RISK__MAX_DRAWDOWN_PCT=0.20
TRENDCHIMP_RISK__MAX_POSITION_PCT=0.20
TRENDCHIMP_RISK__ALLOW_SHORT=true
# Startup stop-recovery: fallback stop distance used only if ATR can't be computed.
TRENDCHIMP_RISK__RECOVERY_FALLBACK_STOP_PCT=0.10
# Positions whose symbol drops out of the daily universe are handed off to a broker
# trailing stop. Trail distance is atr_mult × N (ATR); the percent is only a fallback
# used when ATR can't be computed (too little history).
TRENDCHIMP_RISK__ORPHAN_TRAILING_ATR_MULT=2.0
TRENDCHIMP_RISK__ORPHAN_TRAILING_STOP_PCT=0.05

# --- Small-account preset (~$1-2K) ---
# Defaults above target a $10-20K account; with whole-share sizing and the 20%
# position cap, a $1-2K account rounds most S&P names to 0 shares. Uncomment to bias
# the screener to cheaper names and size more aggressively so it actually trades:
#   TRENDCHIMP_SCREENER__MAX_PRICE=50      # only screen sub-$50 names
#   TRENDCHIMP_SCREENER__MIN_PRICE=5       # skip illiquid penny names
#   TRENDCHIMP_RISK__RISK_PER_TRADE_PCT=0.02   # 2% so whole-share sizing yields >=1 share
#   TRENDCHIMP_RISK__MAX_POSITION_PCT=0.34     # allow a single cheap name to be a bigger slice
#   TRENDCHIMP_RISK__ALLOW_SHORT=false         # small cash accounts support shorting poorly

# --- Logging ---
TRENDCHIMP_LOGGING__LEVEL=INFO
TRENDCHIMP_LOGGING__FORMAT=console
TRENDCHIMP_LOGGING__AUDIT_LOG_PATH=./logs/trades.jsonl
